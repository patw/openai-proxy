# =============================================================================
# Fast model config (default) — used when client requests "fast" or any
# unrecognized model name.
# =============================================================================
# Backward-compatible: these also accept the old REAL_BASE_URL / REAL_API_KEY / REAL_MODEL_NAME names.
FAST_BASE_URL=https://api.fireworks.ai/inference/v1
FAST_API_KEY=your-api-key-here
FAST_MODEL_NAME=accounts/fireworks/models/deepseek-v4-pro

# =============================================================================
# Smart model config (optional) — used when client requests "smart".
# If any of these are left unset (or commented out), the corresponding value
# from the fast model config is used as a fallback.
# =============================================================================
# SMART_BASE_URL=https://api.openai.com/v1
# SMART_API_KEY=sk-your-smart-api-key
# SMART_MODEL_NAME=gpt-4o

# =============================================================================
# Server settings
# =============================================================================
# The port your proxy will run on
PROXY_PORT=8086
# The IP address to bind the server to (use your LAN IP to avoid WAN exposure)
BIND_HOST=0.0.0.0
# Timeout in seconds for backend requests (default: 120).
# When this timeout expires — or the backend returns a 5xx/429 error — the
# proxy will automatically fall back to the OTHER model if it's configured.
# Set to 0 to disable timeouts entirely.
PROXY_TIMEOUT=120
