# The actual endpoint of the real provider
REAL_BASE_URL=https://api.fireworks.ai/inference/v1
# The actual API key for the real provider
REAL_API_KEY=your-api-key-here
# The actual model you want to force everything to use
REAL_MODEL_NAME=accounts/fireworks/models/deepseek-v4-pro
# The port your proxy will run on
PROXY_PORT=8086
